---
interface Props {
  tag: string;
  href?: string;
}

const { tag, href } = Astro.props;
---

{href
  ? <a href={href} class="tag-pill">{tag}</a>
  : <span class="tag-pill">{tag}</span>
}

<style>
  .tag-pill {
    display: inline-block;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.22rem 0.58rem;
    font-size: 0.72rem;
    font-weight: 650;
    color: var(--text-soft);
    text-decoration: none;
    line-height: 1;
  }

  a.tag-pill:hover {
    color: var(--accent);
  }
</style>
