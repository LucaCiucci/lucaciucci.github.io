---
import { Md } from '@luca/astro-ui/components';
import TagPill from '../TagPill.astro';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  date?: Date;
  href: string;
  image?: string;
  imageAlt?: string;
  tags?: string[];
}

const { title, subtitle, description, date, href, image, imageAlt = '', tags = [] } = Astro.props;
const dateStr = date ? date.toISOString().split('T')[0] : '';
---

<li class="details-box">
    {image && <a href={href}><img src={image} alt={imageAlt} class="list-image" /></a>}
    {dateStr ? <span class="muted">{dateStr}: </span> : ''}<a href={href}><Md kind="inline" text={title || 'Untitled'} /></a>
  {
  description
    ? <>
        {subtitle && <details>
          <summary class="styled"><span class="subtitle-inline"><Md kind="inline" text={subtitle} /></span></summary><Md text={description} />
        </details>}
      </>
    : <>{subtitle && <span class="subtitle-inline"> — <Md kind="inline" text={subtitle} /></span>}</>
  }
  {tags.length > 0 && (
    <ul class="tag-list">
      {tags.map(t => <li><TagPill tag={t} href={`/blog/tag/${t}/`} /></li>)}
    </ul>
  )}
</li>

<style>
  .subtitle-inline {
    color: var(--text-muted);
  }

  li {
    list-style: none;
    overflow: hidden;
  }

  a {
    color: var(--text);
    font-weight: 600;
    text-decoration: none;
  }

  a:hover {
    color: var(--accent);
  }

  details {
    border: none;
    margin: 0;
    padding: 0;
  }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.3rem 0 0;
    margin: 0;
    list-style: none;
  }

  .tag-list li {
    overflow: visible;
  }

  .list-image {
    float: right;
    width: 7rem;
    height: 5rem;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
</style>
