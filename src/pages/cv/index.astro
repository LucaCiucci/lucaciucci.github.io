---
import MainLayout from '../../layouts/MainLayout.astro';
import { Timeline } from '@luca/astro-ui/components';
import CvHero from '../../components/cv/CvHero.astro';
import InterestCard from '../../components/cv/InterestCard.astro';
import PublicationList from '../../components/cv/PublicationList.astro';
import WorkExperienceList from '../../components/cv/WorkExperienceList.astro';
import cv from './cv-data.yaml';
import publications from './pubblications.yaml';
import './style.css';

const meta = {
  description: cv.summary,
  image: `/cv-assets/${cv.portrait}`,
  image_alt: cv.name,
};
---
<MainLayout
  title="Luca Ciucci — Curriculum Vitae"
  show_page_nav={true}
  heading_depth={1}
  meta={meta}
>
  <CvHero
    name={cv.name}
    info={cv.info}
    role={cv.role}
    summary={cv.summary}
    keywords={cv.keywords}
    portrait={`/cv-assets/${cv.portrait}`}
    github={cv.socials.find((social: any) => social.platform === 'GitHub')?.link}
    pdf="/cv.pdf"
  />

  <h1>Main interests</h1>

  <p class="cv-section-intro">{cv.interests.intro}</p>

  <div class="cv-interests">
    {cv.interests.groups.map((group: any) => <InterestCard {...group} />)}
  </div>

  <h1>Work experience</h1>

  <WorkExperienceList entries={cv.work_experience} />

  <h1>Publications</h1>

  <PublicationList publications={publications} />

  <h1>Education</h1>

  <Timeline entries={cv.education} imageBasePath="/cv-assets/" />

  <h1>Educational projects</h1>

  <Timeline entries={cv.educational_projects} imageBasePath="/cv-assets/" />
</MainLayout>
