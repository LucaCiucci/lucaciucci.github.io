---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { Md } from '@luca/astro-ui/components';
import PostListItem from '../../../components/blog/PostListItem.astro';
import tagDefs from '../../../content/blog-tags.yaml';

export async function getStaticPaths() {
  const posts = await getCollection('blog_posts');
  const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
  return allTags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter(p => p.data.tags?.includes(tag))
        .sort((a, b) => (b.data.date ?? new Date(0)).getTime() - (a.data.date ?? new Date(0)).getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;
const tagMeta = tagDefs.tags?.[tag as keyof typeof tagDefs.tags];
const title = `Tag: ${tag}`;
---

<MainLayout title={title}>
  <article>
    <header style="margin-bottom: 2rem;">
      <a class="back" href="/blog" style="display: inline-flex; margin-bottom: 1.5rem; color: var(--text-muted); font-size: 0.8rem; font-weight: 700; text-decoration: none;">← All posts</a>
      <h1 style="margin: 0 0 0.5rem; font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.04em;">{tag}</h1>
      {tagMeta?.description && <p style="margin: 0; color: var(--text-muted); font-size: 1.08rem;">{tagMeta.description}</p>}
    </header>

    {posts.length === 0
      ? <p style="color: var(--text-muted);">No posts with this tag yet.</p>
      : <ul style="display: flex; flex-direction: column; gap: 1rem; padding: 0; list-style: none;">
          {posts.map(post => (
            <PostListItem
              title={post.data.title}
              subtitle={post.data.subtitle}
              description={post.data.description}
              date={post.data.date}
              href={`/blog/${post.id}`}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              tags={post.data.tags}
            />
          ))}
        </ul>}
  </article>
</MainLayout>
