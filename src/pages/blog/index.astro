---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { Code } from 'astro:components';
import { Md } from '@luca/astro-ui/components';
import PostListItem from '../../components/blog/PostListItem.astro';
import TagPill from '../../components/TagPill.astro';

const all_posts = (await getCollection('blog_posts'))
  .sort((a, b) => (b.data.date ?? new Date(0)).getTime() - (a.data.date ?? new Date(0)).getTime());

const all_tags = [...new Set(all_posts.flatMap(p => p.data.tags))].sort();
---

<MainLayout title="Blog">
  <h1>Posts</h1>

  {all_posts.map(post => (
    <PostListItem
      title={post.data.title}
      subtitle={post.data.subtitle}
      description={post.data.description}
      date={post.data.date}
      href={`/blog/${post.id}`}
      image={post.data.image}
      imageAlt={post.data.imageAlt}
      tags={post.data.tags}
    />
  ))}

  <h2>Tags</h2>

  <ul class="tag-list">
    {all_tags.map(t => <li><TagPill tag={t} href={`/blog/tag/${t}/`} /></li>)}
  </ul>

  {import.meta.env.DEV && <details>
    <summary>All posts (JSON)</summary>
    <Code code={JSON.stringify(all_posts, null, 2)} lang="json" />
  </details>}
</MainLayout>

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0;
    list-style: none;
  }
</style>
