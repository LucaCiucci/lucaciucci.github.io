---
import { type PageMeta } from "@luca/astro-ui/layouts";
import { Md } from "@luca/astro-ui/components";
import MainLayout from "./MainLayout.astro";
import TagPill from "../components/TagPill.astro";

interface PageHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  /** Optional subtitle shown under the title in the header */
  subtitle?: string;
  /** Meta description – also used for og:description if meta.description is not set */
  description: string;
  /** Tags displayed as pills under the title */
  tags?: string[];
  /** Hero image for meta tags */
  image?: string;
  imageAlt?: string;
  /** URL for the "back" link in the header (e.g. "/projects") */
  backHref?: string;
  /** Label for the "back" link (e.g. "← All projects") */
  backLabel?: string;
  /** Eyebrow text shown above the title (e.g. "Project archive · 2026") */
  eyebrow?: string;
  /** If set, tags become links to {tagBaseHref}{tag}/ (e.g. "/blog/tag/") */
  tagBaseHref?: string;
  meta?: PageMeta;
  headings?: PageHeading[];
  frontmatter?: Props;
}

const { title, subtitle, description, tags = [], image, imageAlt, backHref, backLabel, eyebrow, tagBaseHref, meta = {}, headings } = {
  ...(Astro.props.frontmatter || {}),
  ...Astro.props,
};

meta.description = meta.description ?? (() => {
  const parts = [subtitle, description].filter(Boolean);
  // Avoid duplication when subtitle and description are the same (e.g. projects)
  return parts.length > 1 && parts[0] === parts[1] ? parts[0] : parts.join('\n\n');
})();
meta.type = meta.type ?? 'article';
meta.image = meta.image ?? image;
meta.image_alt = meta.image_alt ?? imageAlt;
---

<MainLayout
  title={title}
  meta={meta}
  headings={headings}
>
  <article class="article">
    <header>
      {backHref && backLabel && <a class="back" href={backHref}>{backLabel}</a>}
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1><Md kind="inline" text={title || '<no title>'} /></h1>
      {subtitle && <p class="subtitle"><Md kind="inline" text={subtitle} /></p>}
      {tags.length > 0 && <ul>{tags.map(t => <li>{tagBaseHref ? <TagPill tag={t} href={`${tagBaseHref}${t}/`} /> : <TagPill tag={t} />}</li>)}</ul>}
    </header>
    <div class="content"><slot /></div>
  </article>
</MainLayout>
<style>
  header {
    max-width: 48rem;
    margin-bottom: 3.5rem;
  }

  .back {
    display: inline-flex;
    margin-bottom: 2rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 8vw, 4.5rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
  }

  .subtitle {
    margin: 1rem 0 0;
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    margin: 1.2rem 0 0;
    padding: 0;
    gap: 0.4rem;
    list-style: none;
  }

  .content {
    color: var(--text-soft);
  }

  .content :global(h2) {
    margin: 3.5rem 0 0.8rem;
    color: var(--text);
    font-size: clamp(1.5rem, 4vw, 2rem);
    letter-spacing: -0.035em;
  }

  .content :global(p),
  .content :global(li) {
    line-height: 1.75;
  }

  .content :global(img) {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .content :global(iframe),
  .content :global(video) {
    width: 100%;
    max-width: 100%;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--background-raised);
  }

  .content :global(.video) {
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .content :global(figure) {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 1rem 0;
    margin-left: auto;
    margin-right: auto;
    border: 1px solid var(--border);
    padding: 0.25em;
    border-radius: 0.25rem;
    max-width: 80%;
  }

  .content :global(figure) :global(figcaption) {
    margin-top: 0.25em;
    font-size: 0.82rem;
    color: var(--text-muted);
    text-align: center;
  }

  .content :global(.square-embed) {
    width: min(100%, 620px);
    aspect-ratio: 1;
  }

  /* empty <p> are artifacts of markdown parsing, and can cause unwanted spacing. */
  .content :global(p:empty) {
    display: none;
  }

  /* <p> with only a <img> are also artifacts of markdown parsing, and can
    cause unwanted spacing. This currently happens in figures. */
  .content :global(p:has(> img:only-child)) {
    display: contents;
  }

  /* make the blockquote look nicer */
  .content :global(blockquote) {
    margin: 1.5rem 0;
    padding-left: 1rem;
    border-left: 3px solid var(--border);
    color: var(--text-muted);
  }
</style>
