---
import { type PageMeta } from "@luca/astro-ui/layouts";
import Article from './Article.astro';
import { Callout, Md } from '@luca/astro-ui/components';

interface PageHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  subtitle?: string;
  date: string | Date;
  description: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  meta?: PageMeta;
  headings?: PageHeading[];
  frontmatter?: Props;
}

const { title, subtitle, date, description, tags, image, imageAlt, meta, headings } = {
  ...(Astro.props.frontmatter || {}),
  ...Astro.props,
};

const dateStr = (date instanceof Date ? date.toISOString() : String(date)).split('T')[0];
const eyebrow = `Blog post · ${dateStr}`;
---

<Article
  title={title}
  subtitle={subtitle}
  description={description}
  tags={tags}
  image={image}
  imageAlt={imageAlt}
  backHref="/blog"
  backLabel="← All posts"
  eyebrow={eyebrow}
  meta={meta}
  headings={headings}
>
  {description && <Callout variant="tldr"><Md text={description} /></Callout>}
  <slot />
</Article>
